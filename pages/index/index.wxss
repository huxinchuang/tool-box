.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-card {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.input-item {
  flex: 1;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx 12rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}

.form-actions button {
  flex: 1;
  margin: 0;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.preview-card {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.preview-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.table-scroll {
  width: 100%;
  overflow-x: auto;
  margin-bottom: 20rpx;
}

.preview-table {
  display: table;
  min-width: 100%;
  border-collapse: collapse;
  font-size: 24rpx;
}

.table-row {
  display: table-row;
}

.table-cell {
  display: table-cell;
  border: 1rpx solid #ccc;
  padding: 16rpx 8rpx;
  vertical-align: middle;
  text-align: center;
  background-color: white;
}

.header .table-cell {
  background-color: #f2f2f2;
  font-weight: bold;
}

.generate-btn {
  margin-top: 20rpx;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

.result-area {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.result-title {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.preview-image {
  width: 100%;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.save-btn {
  width: 60%;
  margin: 0 auto;
}